<section id="rua" style="background:var(--white)">
    <div class="container">
        <div class="section-label" data-lang-en="The Framework" data-lang-zh="框架体系" data-lang-jp="フレームワーク" data-lang-fr="Le Cadre">The Framework</div>
        <div class="red-bar"></div>
        <h2 data-lang-en="RUA - Recognise · Understand · Apply" data-lang-zh="RUA - 识别 · 理解 · 应用" data-lang-jp="RUA - 認識 · 理解 · 応用" data-lang-fr="RUA - Reconnaître · Comprendre · Appliquer">RUA - Recognise · Understand · Apply</h2>
        <p style="color:var(--gray-600);font-weight:400;max-width:520px;margin-bottom:8px" data-lang-en="A meta-cognitive operating system for learning in the AI era." data-lang-zh="AI时代的元认知学习操作系统。" data-lang-jp="AI時代のためのメタ認知学習オペレーティングシステム。" data-lang-fr="Un système d'exploitation méta-cognitif pour l'apprentissage à l'ère de l'IA.">A meta-cognitive operating system for learning in the AI era.</p>
        <div class="flip-grid">
            <div class="flip-card"><div class="flip-inner">
                <div class="flip-front"><div class="flip-letter">R</div><h3 data-lang-en="Recognise" data-lang-zh="识别" data-lang-jp="認識" data-lang-fr="Reconnaître">Recognise</h3><p data-lang-en="Decompose the learning target into bite-sized chunks." data-lang-zh="将学习目标分解为小块。" data-lang-jp="学習目標を小さなチャンクに分解します。" data-lang-fr="Décomposer la cible d'apprentissage en petits morceaux.">Decompose the learning target into bite-sized chunks.</p><div class="flip-hint" data-lang-en="Flip for more" data-lang-zh="翻转查看" data-lang-jp="タップして詳細" data-lang-fr="Retourner pour plus">Flip for more</div></div>
                <div class="flip-back"><h4>🍖 BEEF - Goal Decomposition</h4><ul><li><strong>B</strong>ackground - when, where, who</li><li><strong>E</strong>vidence · CHOP - Caught eye? Highlight? Optimised? Purpose?</li><li><strong>E</strong>xplanation · SOOI - Subjective, Objective, Outlying, Intrinsic</li><li><strong>F</strong>eedback - record the emotion as a signal</li></ul></div>
            </div></div>
            <div class="flip-card"><div class="flip-inner">
                <div class="flip-front"><div class="flip-letter">U</div><h3 data-lang-en="Understand" data-lang-zh="理解" data-lang-jp="理解" data-lang-fr="Comprendre">Understand</h3><p data-lang-en="Deep comprehension before application." data-lang-zh="应用前的深度理解。" data-lang-jp="応用の前に深い理解を。" data-lang-fr="Compréhension profonde avant l'application.">Deep comprehension before application.</p><div class="flip-hint" data-lang-en="Flip for more" data-lang-zh="翻转查看" data-lang-jp="タップして詳細" data-lang-fr="Retourner pour plus">Flip for more</div></div>
                <div class="flip-back"><h4>🧩 3C - Deep Comprehension</h4><ul><li><strong>C</strong>ollocation - what does this naturally pair with?</li><li><strong>C</strong>ontexts - in what situations does this appear?</li><li><strong>C</strong>onnotation - what's the unspoken meaning?</li></ul></div>
            </div></div>
            <div class="flip-card"><div class="flip-inner">
                <div class="flip-front"><div class="flip-letter">A</div><h3 data-lang-en="Apply" data-lang-zh="应用" data-lang-jp="応用" data-lang-fr="Appliquer">Apply</h3><p data-lang-en="Systematic practice with feedback loops." data-lang-zh="带反馈循环的系统练习。" data-lang-jp="フィードバックループ付きの体系的な練習。" data-lang-fr="Pratique systématique avec boucles de rétroaction.">Systematic practice with feedback loops.</p><div class="flip-hint" data-lang-en="Flip for more" data-lang-zh="翻转查看" data-lang-jp="タップして詳細" data-lang-fr="Retourner pour plus">Flip for more</div></div>
                <div class="flip-back"><h4>🎯 GAP - Deliberate Practice</h4><ul><li><strong>G</strong>auge - where exactly is the gap?</li><li><strong>A</strong>nalyse - trace back to a Recognise chunk</li><li><strong>P</strong>ractice - drill, fail, correct, repeat</li></ul></div>
            </div></div>
        </div>
    </div>
</section>

<section id="story">
    <div class="container">
        <div class="section-label" data-lang-en="My Journey" data-lang-zh="我的旅程" data-lang-jp="私の歩み" data-lang-fr="Mon Parcours">My Journey</div>
        <div class="red-bar"></div>
        <h2 data-lang-en="From live stage to classroom to code" data-lang-zh="从现场舞台到教室再到代码" data-lang-jp="ライブステージから教室、そしてコードへ" data-lang-fr="De la scène à la salle de classe au code">From live stage to classroom to code</h2>
        <div style="margin-top:20px">
            <div class="tl-item"><div class="tl-year"><span class="tl-dot"></span>2012</div><div class="tl-content"><h4 data-lang-en="Backstreet Boys Tour Interpreter" data-lang-zh="后街男孩巡演口译员" data-lang-jp="Backstreet Boysツアー通訳" data-lang-fr="Interprète de la tournée Backstreet Boys">Backstreet Boys Tour Interpreter</h4><p data-lang-en="20,000 people. Live mic. Zero margin. Where I learned language is resonance, not rules." data-lang-zh="两万人。现场麦克风。零容错。在这里我学到:语言是共鸣,不是规则。" data-lang-jp="2万人。ライブマイク。失敗は許されない。言葉はルールではなく共鳴だと学んだ場所。" data-lang-fr="20 000 personnes. Micro en direct. Zéro marge. Là où j'ai appris que la langue est résonance, pas des règles.">20,000 people. Live mic. Zero margin. Where I learned language is resonance, not rules.</p></div></div>
            <div class="tl-item"><div class="tl-year"><span class="tl-dot"></span>2014-20</div><div class="tl-content"><h4 data-lang-en="EF Expert Teacher · Trainer of Trainers" data-lang-zh="EF专家教师 · 培训师的培训师" data-lang-jp="EFエキスパート講師 · トレーナーのトレーナー" data-lang-fr="Enseignant Expert EF · Formateur de Formateurs">EF Expert Teacher · Trainer of Trainers</h4><p data-lang-en="Highest rank. Built the playbook for West China. Watched the same pattern everywhere: content without architecture." data-lang-zh="最高级别。为华西地区构建教学手册。到处都看到同样的模式:有内容,无架构。" data-lang-jp="最高ランク。中国西部地区のプレイブックを構築。どこでも同じパターンを目にした:アーキテクチャなきコンテンツ。" data-lang-fr="Plus haut rang. Construit le playbook pour l'Ouest de la Chine. Observé le même schéma partout : du contenu sans architecture.">Highest rank. Built the playbook for West China. Watched the same pattern everywhere: content without architecture.</p></div></div>
            <div class="tl-item"><div class="tl-year"><span class="tl-dot"></span>2021-25</div><div class="tl-content"><h4 data-lang-en="Independent Teacher & Researcher" data-lang-zh="独立教师与研究者" data-lang-jp="独立講師・研究者" data-lang-fr="Enseignant Indépendant & Chercheur">Independent Teacher & Researcher</h4><p data-lang-en="Built the RUA learning framework. Developed MFP/CCC/GAP taxonomy. 200+ students. 7 institutions across Chengdu." data-lang-zh="构建RUA学习框架。开发MFP/CCC/GAP分类体系。200+学生。成都7所机构。" data-lang-jp="RUA学習フレームワークを構築。MFP/CCC/GAP分類体系を開発。200名以上の生徒。成都の7機関で指導。" data-lang-fr="Construit le cadre RUA. Développé la taxonomie MFP/CCC/GAP. 200+ étudiants. 7 institutions à Chengdu.">Built the RUA learning framework. Developed MFP/CCC/GAP taxonomy. 200+ students. 7 institutions across Chengdu.</p></div></div>
            <div class="tl-item"><div class="tl-year"><span class="tl-dot active"></span>2026</div><div class="tl-content"><h4>DynamOS</h4><p data-lang-en="Building the cognitive OS for AI-native education. Deployed DynaSaurus. Building at 4AM." data-lang-zh="构建AI原生教育的认知操作系统。已部署DynaSaurus。凌晨四点仍在编码。" data-lang-jp="AIネイティブ教育のための認知OSを構築中。DynaSaurusをデプロイ。午前4時に開発中。" data-lang-fr="Construction de l'OS cognitif pour l'éducation IA-native. DynaSaurus déployé. Construction à 4h du matin.">Building the cognitive OS for AI-native education. Deployed DynaSaurus. Building at 4AM.</p></div></div>
            <a href="/tedx-speech" class="tedx-mention">
                <div class="tedx-mention-img"><img src="/tedx-hero.jpg" alt="TEDx" loading="lazy"></div>
                <div class="tedx-mention-body">
                    <div class="tedx-mention-kicker">TEDxWangjiangSt 2026</div>
                    <div class="tedx-mention-title">Bridge the Gap</div>
                    <div class="tedx-mention-desc" data-lang-en="From touring with the Backstreet Boys to building an education OS - read the talk that introduced R.U.A. and Dynamos →" data-lang-zh="从后街男孩巡演到搭建教育操作系统 - 阅读这篇介绍R.U.A.和DynamOS的演讲 →" data-lang-jp="Backstreet Boysの通訳から教育OSの構築へ - R.U.A.とDynamOSを紹介した講演を読む →" data-lang-fr="De la tournée avec les Backstreet Boys à la création d&apos;un OS éducatif - lisez le talk qui a présenté R.U.A. et DynamOS →">From touring with the Backstreet Boys to building an education OS - read the talk that introduced R.U.A. and DynamOS <span class="tedx-mention-arrow">→</span></div>
                </div>
            </a>
        </div>
    </div>
</section>

<section id="contact" style="text-align:center">
    <div class="container">
        <div class="section-label" data-lang-en="Get in Touch" data-lang-zh="与我联系" data-lang-jp="お問い合わせ" data-lang-fr="Contactez-moi">Get in Touch</div>
        <div class="red-bar" style="margin:0 auto 20px"></div>
        <h2 data-lang-en="Work with Kee" data-lang-zh="与Kee合作" data-lang-jp="Keeと働く" data-lang-fr="Travailler avec Kee">Work with Kee</h2>
        <p style="color:var(--gray-600);font-weight:400;max-width:420px;margin:0 auto" data-lang-en="Book a demo. Ask about IELTS coaching. Discuss AI-native education. Kee replies personally." data-lang-zh="预约演示。咨询雅思辅导。探讨AI原生教育。Kee亲自回复。" data-lang-jp="デモを予約。IELTSコーチングについて質問。AIネイティブ教育を議論。Keeが直接返信します。" data-lang-fr="Réservez une démo. Renseignez-vous sur le coaching IELTS. Discutez de l'éducation IA-native. Kee répond personnellement.">Book a demo. Ask about IELTS coaching. Discuss AI-native education. Kee replies personally.</p>
        <div class="contact-row">
            <div class="ci"><div class="cl">WeChat</div><div class="cv"><a href="#" onclick="copyWechat();return false;">keedahooman</a></div></div>
            <div class="ci"><div class="cl">WhatsApp</div><div class="cv"><a href="https://wa.me/447440622158">+44 7440 622158</a></div></div>
        </div>
    </div>
</section>

<footer>
    <div class="container" data-lang-en="Kee Lee · AI-Native Education Architect · Chengdu · rkrk.io · © 2026" data-lang-zh="Kee Lee · AI原生教育架构师 · 成都 · rkrk.io · © 2026" data-lang-jp="Kee Lee · AIネイティブ教育アーキテクト · 成都 · rkrk.io · © 2026" data-lang-fr="Kee Lee · Architecte Éducatif IA-Native · Chengdu · rkrk.io · © 2026">Kee Lee · AI-Native Education Architect · Chengdu · rkrk.io · © 2026</div>
</footer>

<!-- AI CHAT WIDGET -->
<div class="floating-dock">
    <div class="dock-chat-section">
        <button id="chatTrigger" class="dock-chat-trigger" onclick="toggleChat()">
            <span class="trigger-icon">🦄</span>
            <span class="trigger-label" data-lang-en="Pick Kee's Brain" data-lang-zh="问问 Kee 吧" data-lang-jp="Keeに聞いてみ" data-lang-fr="Demande à Kee">Pick Kee's Brain</span>
        </button>
        <div id="chatPanel" class="chat-panel" style="display:none">
            <div class="chat-panel-header">
                <div class="chat-panel-brand">
                    <span class="chat-panel-avatar">🦄</span>
                    <div>
                        <strong>Kee's AI Assistant</strong>
                        <span data-lang-en="IELTS tips, DynamOS insights, or just say hi" data-lang-zh="雅思攻略 · DynamOS解析 · 打个招呼" data-lang-jp="IELTSのコツ・DynamOSの知見・気軽に話そう" data-lang-fr="Astuces IELTS, aperçus DynamOS, ou juste bonjour">IELTS tips, DynamOS insights, or just say hi</span>
                    </div>
                </div>
                <button class="chat-panel-close" onclick="toggleChat()">×</button>
            </div>
            <div id="chatMessages" class="chat-panel-messages">
                <div class="chat-msg bot">
                    <span class="chat-msg-avatar">🦄</span>
                    <div class="chat-msg-content" data-lang-en="Hey! 👋 I'm Kee's AI sidekick. IELTS strategy? How DynamOS works? Whether Kee ever sleeps? I've got answers." data-lang-zh="嘿!👋 我是Kee的AI助手。雅思策略?DynamOS怎么用?Kee到底睡不睡觉?我都有答案。" data-lang-jp="よっ!👋 KeeのAIパートナーだよ。IELTS対策?DynamOSの仕組み?Keeの睡眠事情?なんでも答えるよ。" data-lang-fr="Salut ! 👋 Le partenaire IA de Kee. Stratégie IELTS ? Comment marche DynamOS ? Si Kee dort ? J'ai les réponses.">Hey! 👋 I'm Kee's AI sidekick. IELTS strategy? How DynamOS works? Whether Kee ever sleeps? I've got answers.</div>
                </div>
            </div>
            <div class="chat-panel-input">
                <textarea id="chatInput" class="chat-panel-field" rows="1" data-lang-en-placeholder="Ask anything..." data-lang-zh-placeholder="随便问..." data-lang-jp-placeholder="何でも聞いて..." data-lang-fr-placeholder="Demandez..." placeholder="Ask anything..." onkeydown="var e=event;if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendChat()}" oninput="this.style.height='auto';this.style.height=Math.min(this.scrollHeight,120)+'px'"></textarea>
                <button class="chat-panel-send" onclick="sendChat()">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
/* ═══════════════════════════════════════════
   LANGUAGE SWITCHER
   ═══════════════════════════════════════════ */
var currentLang = 'en';

function applyLang(lang) {
    currentLang = lang;
    document.querySelectorAll('[data-lang-' + lang + ']').forEach(function(el) {
        el.textContent = el.getAttribute('data-lang-' + lang);
    });
    // Update placeholder for chat input
    var chatInput = document.getElementById('chatInput');
    var phKey = 'data-lang-' + lang + '-placeholder';
    if (chatInput && chatInput.hasAttribute(phKey)) {
        chatInput.placeholder = chatInput.getAttribute(phKey);
    }
    // Update dropdown active state
    document.querySelectorAll('.lang-option').forEach(function(opt) {
        opt.classList.toggle('active', opt.getAttribute('data-lang') === lang);
    });
    // Update current display
    var labels = { en:'EN', zh:'中文', jp:'日本語', fr:'Français' };
    var currentEl = document.querySelector('.lang-current');
    if (currentEl) currentEl.textContent = labels[lang] || lang.toUpperCase();
    // Persist
    localStorage.setItem('rkrk-lang', lang);
}

function setLang(lang) {
    applyLang(lang);
    document.getElementById('langSwitch').classList.remove('open');
}

function toggleLang(e) {
    e.stopPropagation();
    document.getElementById('langSwitch').classList.toggle('open');
}

// Close dropdown on outside click
document.addEventListener('click', function() {
    document.getElementById('langSwitch').classList.remove('open');
});

// Init from localStorage
(function() {
    var saved = localStorage.getItem('rkrk-lang');
    if (saved && saved !== 'en') {
        applyLang(saved);
    }
})();

/* ═══════════════════════════════════════════
   AI CHAT WIDGET
   ═══════════════════════════════════════════ */
var chatOpen=false,chatLoading=false;
function toggleChat(){chatOpen=!chatOpen;var p=document.getElementById('chatPanel');var t=document.getElementById('chatTrigger');var d=document.querySelector('.floating-dock');if(chatOpen){d.classList.remove('collapsed');p.style.display='flex';setTimeout(function(){requestAnimationFrame(function(){requestAnimationFrame(function(){p.classList.add('open');});});},100);t.classList.add('active');setTimeout(function(){document.getElementById('chatInput').focus();},500)}else{p.classList.remove('open');t.classList.remove('active');setTimeout(function(){p.style.display='none';d.classList.add('collapsed');},200)}}

// Appear after 5s with glow, fold to emoji after 11s
setTimeout(function(){
  var dock=document.querySelector('.floating-dock');
  var trigger=document.getElementById('chatTrigger');
  dock.classList.add('visible');
  trigger.classList.add('glow');
  // Collapse to floating emoji after entrance animation
  setTimeout(function(){dock.classList.add('collapsed');},11000);
},5000);
async function sendChat(){
    if(chatLoading)return;
    var input=document.getElementById('chatInput'),msg=input.value.trim();
    if(!msg)return;input.value='';input.style.height='auto';chatLoading=true;
    var msgsDiv=document.getElementById('chatMessages');
    msgsDiv.innerHTML+='<div class="chat-msg user"><div class="chat-msg-content">'+esc(msg)+'</div></div>';
    var botDiv=document.createElement('div');botDiv.className='chat-msg bot';
    botDiv.innerHTML='<span class="chat-msg-avatar">🦄</span><div class="chat-msg-content md-output" id="streamTarget"></div>';
    msgsDiv.appendChild(botDiv);
    msgsDiv.scrollTop=msgsDiv.scrollHeight;
    try{
        var res=await fetch('https://dynasaurus.rkrk.io/api/kee-bot',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({message:sysPrompt,lang:navigator.language||'en'})});
        var data=await res.json();
        var raw=data.reply||'Sorry, try again.';
        // Post-process: add social links
        raw=raw.replace(/WeChat:\s*keedahooman/gi,'WeChat: <button onclick="copyWechat()" style="background:#09b83e;color:#fff;border:none;padding:4px 10px;border-radius:8px;cursor:pointer;font-size:0.85em;font-weight:600">keedahooman 📋→微信</button>');
        raw=raw.replace(/WhatsApp:\s*\+44\s*7440\s*622158/gi,'WhatsApp: <a href="https://wa.me/447440622158" target="_blank" style="color:var(--green,#25d366);font-weight:600">+44 7440 622158 💬</a>');
        raw=raw.replace(/rkrk@me\.com/gi,'<a href="mailto:rkrk@me.com" style="color:var(--purple);font-weight:600">rkrk@me.com ✉️</a>');
        streamText(raw,document.getElementById('streamTarget'),msgsDiv);
    }catch(e){
        botDiv.querySelector('.md-output').innerHTML='🦕 DynaSaurus is taking a nap. Try <a href="https://dynasaurus.rkrk.io/mini" target="_blank" style="color:var(--purple);font-weight:600">miniSaurus</a> — same dictionary, zero downtime.';
    }
    chatLoading=false;
}
function streamText(text,el,container,pos){
    pos=pos||0;if(pos>=text.length){el.classList.remove('streaming');return}
    if(pos===0){el.classList.add('streaming');el.textContent=''}
    el.innerHTML=renderMd(text.substring(0,pos+1));
    container.scrollTop=container.scrollHeight;
    var delay=text[pos]===' '||text[pos]==='\n'?8:text[pos]==='.'||text[pos]==='!'||text[pos]==='?'?40:text[pos]===','?20:15;
    setTimeout(function(){streamText(text,el,container,pos+1)},delay);
}
function esc(s){var d=document.createElement('div');d.textContent=s;return d.innerHTML;}
function renderMd(text){var h=esc(text);h=h.replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>').replace(/\*(.+?)\*/g,'<em>$1</em>').replace(/`(.+?)`/g,'<code>$1</code>').replace(/\[(.+?)\]\((.+?)\)/g,'<a href="$2" target="_blank">$1</a>').replace(/\n/g,'<br>');h=h.replace(/(<br>)?([*-] .+?)(?=<br>)/g,function(m,br,item){return (br||'')+'<li>'+item.substring(2)+'</li>';});h=h.replace(/((?:<li>[^<]*<\/li><br>)+)/g,function(m){return '<ul>'+m.replace(/<br>/g,'')+'</ul>';});return h;}
function copyWechat(){var id='keedahooman';var done=function(){setTimeout(function(){window.location.href='weixin://';},200)};if(navigator.clipboard){navigator.clipboard.writeText(id).then(done).catch(done)}else{var ta=document.createElement('textarea');ta.value=id;ta.style.position='fixed';ta.style.opacity='0';document.body.appendChild(ta);ta.select();document.execCommand('copy');document.body.removeChild(ta);done()}}
document.querySelectorAll('.flip-card').forEach(function(c){c.addEventListener('click',function(e){this.classList.toggle('flipped');});c.addEventListener('touchend',function(e){e.preventDefault();this.classList.toggle('flipped');});});

// ═══ Staggered Reveal on Load ═══
document.querySelectorAll('.reveal').forEach(function(el){el.classList.add('visible');});

// ═══ Stat Counter Animation ═══
(function(){
  var fired=false;
  var stats=document.querySelector('.hero-stats');
  function animateNums(){
    if(fired||!stats)return;
    var nums=stats.querySelectorAll('.num');
    nums.forEach(function(n){
      var numSpan=n.querySelector('#yearsStat')||n;
      var txt=numSpan.textContent.trim();
      var isYear=numSpan.id==='yearsStat';
      var target=parseFloat(txt);
      if(isNaN(target))return;
      var suffix=isYear?'':(txt.indexOf('.')>-1?'.0':'');
      var duration=1200;
      var start=performance.now();
      function frame(now){
        var p=Math.min((now-start)/duration,1);
        var eased=1-Math.pow(1-p,3);
        var val=isYear?Math.round(target*eased):(Math.round(target*eased*10)/10);
        numSpan.textContent=val+(isYear?'':(Number.isInteger(val)?'.0':''));
        if(p<1)requestAnimationFrame(frame);
        else numSpan.textContent=txt;
      }
      requestAnimationFrame(frame);
    });
    fired=true;
  }
  var obs=new IntersectionObserver(function(entries){
    if(entries[0].isIntersecting){animateNums();obs.disconnect();}
  },{threshold:0.3});
  if(stats)obs.observe(stats);
  setTimeout(animateNums,600);
})();
</script>

<!-- ── Mouse-tracking card glow ── -->
<script>
(function(){
  document.querySelectorAll('.card').forEach(function(card){
    card.addEventListener('mousemove',function(e){
      var r=card.getBoundingClientRect();
      var x=((e.clientX-r.left)/r.width*100).toFixed(1);
      var y=((e.clientY-r.top)/r.height*100).toFixed(1);
      card.style.setProperty('--mouse-x',x+'%');
      card.style.setProperty('--mouse-y',y+'%');
    });
  });
})();
</script>

<!-- ── Nav scroll effect ── -->
<script>
(function(){
  var nav=document.querySelector('nav');
  window.addEventListener('scroll',function(){
    nav.classList.toggle('scrolled',window.scrollY>10);
  });
})();
</script>

<!-- ── Cursor Follow Glow ── -->
<div id="cursorGlow" style="position:fixed;pointer-events:none;z-index:9999;width:300px;height:300px;border-radius:50%;background:radial-gradient(circle,rgba(159,68,211,0.06) 0%,rgba(255,36,66,0.03) 30%,transparent 70%);transform:translate(-50%,-50%);transition:opacity 0.5s;opacity:0"></div>
<script>
(function(){
  var glow=document.getElementById('cursorGlow');
  var timeout;
  document.addEventListener('mousemove',function(e){
    glow.style.left=e.clientX+'px';
    glow.style.top=e.clientY+'px';
    glow.style.opacity='1';
    clearTimeout(timeout);
    timeout=setTimeout(function(){glow.style.opacity='0';},2000);
  });
  document.addEventListener('mouseleave',function(){glow.style.opacity='0';});
})();
</script>

<!-- ── Visitor Analytics Beacon ── -->
<script>
(function(){
  var d=document,r=d.referrer||'',u=location.pathname+location.search,t=Date.now(),
  w=screen.width,h=screen.height,l=navigator.language||'';
  var img=new Image();
  img.src='/api/analytics?r='+encodeURIComponent(r)+'&u='+encodeURIComponent(u)+'&t='+t+'&w='+w+'&h='+h+'&l='+encodeURIComponent(l);
})();
</script>

</body>
</html>
