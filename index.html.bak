                <button class="lang-btn" onclick="toggleLang(event)">
                    🌐 <span class="lang-current">EN</span>
                    <span class="lang-arrow">▾</span>
                </button>
                <div class="lang-dropdown">
                    <button class="lang-option active" data-lang="en" onclick="setLang('en')">EN</button>
                    <button class="lang-option" data-lang="zh" onclick="setLang('zh')">中文</button>
                    <button class="lang-option" data-lang="jp" onclick="setLang('jp')">日本語</button>
                    <button class="lang-option" data-lang="fr" onclick="setLang('fr')">Français</button>
                </div>
            </div>
            <a href="#contact" class="btn-contact-nav" data-lang-en="contact me" data-lang-zh="联系我" data-lang-jp="連絡" data-lang-fr="contactez-moi">contact me</a>
        </div>
    </div>
</nav>

<section id="hero">
    <div class="container">
        <div class="hero-greeting reveal reveal-d1" data-lang-en="Hi! 👋" data-lang-zh="嗨!👋" data-lang-jp="こんにちは!👋" data-lang-fr="Salut ! 👋">Hi! 👋</div>
        <div class="hero-name reveal reveal-d2">I'm <em>R</em>ic<em>k</em>y</div>
        <div class="hero-meta reveal reveal-d3">
            <span data-lang-en="AI-Native Education Architect" data-lang-zh="教了十年英语,同时搭建了一个教育系统" data-lang-jp="教育とAIをつなぐ" data-lang-fr="Prof, codeur, rêveur">AI-Native Education Architect</span>
            <span> · </span>Chengdu<span> · </span>TEDx 2026
        </div>
        <p class="hero-tagline reveal reveal-d4">
            <span data-lang-en="I draw on nine years of English teaching experience to build AI tools that ease the everyday struggles of teaching and learning. Btw, I also go by Kee." data-lang-zh="我凭借九年英语教学经验,打造AI工具缓解教与学的日常困扰。对了,我也叫Kee。" data-lang-jp="9年の英語教育経験から、教えることと学ぶことの日々の苦労をやわらげるAIツールを作っています。ちなみに、Keeと呼んでください。" data-lang-fr="Fort de neuf ans d&apos;enseignement de l&apos;anglais, je crée des outils IA pour alléger le quotidien des profs et des élèves. Au fait, appelez-moi Kee.">I draw on nine years of English teaching experience to build AI tools that ease the everyday struggles of teaching and learning. Btw, I also go by Kee.</span>
        </p>
        <div class="hero-stats reveal reveal-d5">
            <div class="hs"><div class="num">9.0</div><div class="label" data-lang-en="IELTS Listening" data-lang-zh="雅思听力" data-lang-jp="IELTS リスニング" data-lang-fr="IELTS Listening">IELTS Listening</div></div>
            <div class="hs"><div class="num">8.5</div><div class="label" data-lang-en="IELTS Reading" data-lang-zh="雅思阅读" data-lang-jp="IELTS リーディング" data-lang-fr="IELTS Reading">IELTS Reading</div></div>
            <div class="hs"><div class="num">8.5</div><div class="label" data-lang-en="IELTS Speaking" data-lang-zh="雅思口语" data-lang-jp="IELTS スピーキング" data-lang-fr="IELTS Speaking">IELTS Speaking</div></div>
            <div class="hs"><div class="num"><span id="yearsStat">9</span><span class="num-unit" data-lang-en="yrs" data-lang-zh="年" data-lang-jp="年" data-lang-fr="ans">yrs</span></div><div class="label" data-lang-en="Teaching" data-lang-zh="教龄" data-lang-jp="指導歴" data-lang-fr="Enseignement">Teaching</div></div>
        </div>

            </a>
        </div>
    </div>
</section>


<section id="lab">
    <div class="container">
        <div class="section-label" data-lang-en="The Lab" data-lang-zh="实验室" data-lang-jp="研究室" data-lang-fr="Le Labo">The Lab</div>
        <div class="red-bar"></div>
        <h2 data-lang-en="AI-powered tools. Real classroom results." data-lang-zh="AI驱动的工具。真实的课堂成果。" data-lang-jp="AI搭載ツール。本物の教室成果。" data-lang-fr="Outils IA. Résultats réels en classe.">AI-powered tools. Real classroom results.</h2>
        <div class="grid-3" style="margin-top:24px">
            <a href="/dynamos" class="card"><div style="font-size:1.5rem;margin-bottom:10px">🧠</div><h3>DynamOS</h3><p style="font-size:0.85rem;color:var(--gray-600);font-weight:400" data-lang-en="The Roblox for Education. Teachers build, share, and monetize AI-powered learning tools. Zero code." data-lang-zh="教育界的Roblox。教师构建、分享并变现AI学习工具。零代码。" data-lang-jp="教育のRoblox。教師がAI学習ツールを構築・共有・収益化。ゼロコード。" data-lang-fr="Le Roblox de l'éducation. Les enseignants créent, partagent et monétisent des outils IA. Zéro code.">The Roblox for Education. Teachers build, share, and monetize AI-powered learning tools. Zero code.</p></a>
            <a href="https://dynasaurus.rkrk.io/intro" class="card"><div style="font-size:1.5rem;margin-bottom:10px">🦕</div><h3>DynaSaurus</h3><p style="font-size:0.85rem;color:var(--gray-600);font-weight:400" data-lang-en="AI language tutor. 4 modules. Chunk-based learning. 17 languages. RUA-powered." data-lang-zh="AI语言导师。4大模块。语块学习法。17种语言。RUA驱动。" data-lang-jp="AI言語チューター。4モジュール。チャンク学習。17言語対応。RUA搭載。" data-lang-fr="Tuteur de langue IA. 4 modules. Apprentissage par chunks. 17 langues. Propulsé par RUA.">AI language tutor. 4 modules. Chunk-based learning. 17 languages. RUA-powered.</p></a>
            <a href="https://ielts.rkrk.io" class="card"><div style="font-size:1.5rem;margin-bottom:10px">🦄</div><h3>IELTS with Kee</h3><p style="font-size:0.85rem;color:var(--gray-600);font-weight:400" data-lang-en="170+ cue cards. 3D flip cards. Timed drills. Full P1/P2/P3 speaking toolkit." data-lang-zh="170+话题卡。3D翻转卡片。计时练习。完整P1/P2/P3口语工具包。" data-lang-jp="170以上のキューカード。3Dフリップカード。時間制限ドリル。P1/P2/P3完全スピーキングツールキット。" data-lang-fr="170+ fiches. Cartes 3D. Exercices chronométrés. Boîte à outils complète P1/P2/P3.">170+ cue cards. 3D flip cards. Timed drills. Full P1/P2/P3 speaking toolkit.</p></a>
            <a href="/business-english" class="card"><div style="font-size:1.5rem;margin-bottom:10px">💼</div><h3>Business English</h3><p style="font-size:0.85rem;color:var(--gray-600);font-weight:400" data-lang-en="3 modules: EF Career Advancement · Pronunciation · General English. 50+ lessons. A1-C2. Built with DynamOS." data-lang-zh="三大模块:英孚职业进阶 · 发音训练 · 通用英语。50+节课。A1-C2。基于DynamOS构建。" data-lang-jp="3モジュール:EFキャリア · 発音 · 一般英語。50以上のレッスン。A1〜C2。DynamOS搭載。" data-lang-fr="3 modules : EF Career · Prononciation · Anglais Général. 50+ leçons. A1-C2. Construit avec DynamOS.">3 modules: EF Career Advancement · Pronunciation · General English. 50+ lessons. A1-C2. Built with DynamOS.</p></a>
        </div>
    </div>
</section>

<section id="coop" style="background:var(--white)">
    <div class="container">
        <div class="section-label" data-lang-en="Cooperation Case" data-lang-zh="合作案例" data-lang-jp="協業事例" data-lang-fr="Cas de Coopération">Cooperation Case</div>
        <div class="red-bar"></div>
        <div class="card" style="max-width:660px;padding:36px 32px">
            <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;margin-bottom:8px">
                <img src="/assets/top-education-logo.jpg" alt="托朴教育" style="height:32px;width:auto;border-radius:4px;">
                <h2 style="margin:0;font-size:1.5rem" data-lang-en="托朴教育 × rkrk.io" data-lang-zh="托朴教育 × rkrk.io" data-lang-jp="托朴教育 × rkrk.io" data-lang-fr="托朴教育 × rkrk.io">托朴教育 × rkrk.io</h2>
            </div>
            <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:16px">
                <span style="display:inline-block;background:#fce7f3;color:#9d174d;padding:3px 12px;border-radius:12px;font-size:0.6rem;font-weight:700">Adult English</span>
                <span style="display:inline-block;background:#e0e7ff;color:#3730a3;padding:3px 12px;border-radius:12px;font-size:0.6rem;font-weight:700">General English</span>
                <span style="display:inline-block;background:#d1fae5;color:#065f46;padding:3px 12px;border-radius:12px;font-size:0.6rem;font-weight:700">Built with DynamOS</span>
            </div>
            <p style="color:var(--gray-600);font-weight:400;font-size:0.85rem;margin-bottom:28px;max-width:560px" data-lang-en="Co-developed with 托朴教育. Full RUA-powered course structure — Listen & Notice, Zoom In, Controlled Practice, Free Flow, Theme Deep-Dive, and Cool-Down — delivered through custom demo classes." data-lang-zh="与托朴教育联合开发。完整的RUA驱动课程结构——听与察、聚焦、控制性练习、自由对话、主题深潜和总结作业——通过定制Demo课程呈现。" data-lang-jp="托朴教育と共同開発。RUA搭載の完全なコース構造 — リスニング、ズームイン、制御練習、フリーフロー、テーマ深掘り、クールダウン — をカスタムデモクラスで提供。" data-lang-fr="Co-développé avec 托朴教育. Structure complète du cours propulsé par RUA — Écouter & Remarquer, Zoomer, Pratique Contrôlée, Flux Libre, Plongée Thématique et Retour au Calme — livrée via des cours démo personnalisés.">Co-developed with 托朴教育. Full RUA-powered course structure — Listen & Notice, Zoom In, Controlled Practice, Free Flow, Theme Deep-Dive, and Cool-Down — delivered through custom demo classes.</p>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
                <a href="/adult-english/demo/jun-21" class="card" style="padding:20px;text-decoration:none;color:inherit">
                    <div style="font-size:1.8rem;margin-bottom:6px">🎨</div>
                    <h3 style="font-size:0.95rem;margin-bottom:4px">艺术文化英语 · Art & Culture</h3>
                    <div style="display:flex;gap:4px;flex-wrap:wrap;margin-bottom:4px">
