<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DynamOS — The Education OS | 教育操作系统</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Noto+Sans+SC:wght@300;400;500;700;900&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
/* ================================================================
   DYNAMOS — BENTO EDITORIAL REDESIGN
   Taste Skill v2 compliant | VARIANCE 8 | MOTION 5 | DENSITY 3
   Anti-slop: no AI-purple hero, no equal cards, no glassmorphism walls
   ================================================================ */

/* --- RESET & BASE --- */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;font-size:16px;-webkit-text-size-adjust:100%}
body{
  font-family:'Inter','Noto Sans SC',-apple-system,BlinkMacSystemFont,sans-serif;
  background:#0a0a0f;
  color:#e4e4e7;
  line-height:1.65;
  overflow-x:hidden;
  -webkit-font-smoothing:antialiased;
}

/* --- TYPOGRAPHY --- */
h1,h2,h3,h4,.headline{
  font-family:'Space Grotesk','Noto Sans SC',sans-serif;
  font-weight:600;
  letter-spacing:-0.02em;
}
.en-text{font-family:'Space Grotesk','Inter',sans-serif}
.zh-text{font-family:'Noto Sans SC',sans-serif}

/* --- LANGUAGE TOGGLE --- */
[data-lang-en],[data-lang-zh]{display:none}
.block{display:block}
body[data-lang="zh"] [data-lang-zh]{display:inline}
body[data-lang="zh"] [data-lang-zh].block,[data-lang-zh].block{display:block}
body[data-lang="zh"] [data-lang-en]{display:none}
body[data-lang="en"] [data-lang-en]{display:inline}
body[data-lang="en"] [data-lang-en].block,[data-lang-en].block{display:block}
body[data-lang="en"] [data-lang-zh]{display:none}

/* --- UTILITY --- */
.highlight{color:#c4b5fd;font-weight:600}
.accent-pink{color:#f472b6}
.accent-purple{color:#a78bfa}
.accent-teal{color:#2dd4bf}

/* --- NAV --- */
.toggle-bar{
  position:fixed;top:0;left:0;right:0;z-index:1000;
  display:flex;justify-content:space-between;align-items:center;
  padding:14px 28px;
  background:rgba(10,10,15,0.88);
  backdrop-filter:blur(24px);
  -webkit-backdrop-filter:blur(24px);
  border-bottom:1px solid rgba(255,255,255,0.05);
}
.logo{
  font-family:'Space Grotesk',sans-serif;
  font-size:1.2rem;font-weight:700;
  background:linear-gradient(135deg,#c4b5fd,#f472b6);
  -webkit-background-clip:text;background-clip:text;
  -webkit-text-fill-color:transparent;
  letter-spacing:-0.03em;
}
.nav-links{display:flex;gap:20px;align-items:center}
.nav-links a{
  color:#71717a;text-decoration:none;
  font-size:0.8rem;font-weight:500;
  transition:color 0.2s;
}
.nav-links a:hover{color:#f4f4f5}
.lang-btn{
  background:rgba(255,255,255,0.06);
  border:1px solid rgba(255,255,255,0.1);
  color:#a1a1aa;padding:6px 16px;border-radius:20px;
  font-size:0.75rem;font-weight:600;cursor:pointer;
  transition:all 0.25s;
  font-family:'Inter','Noto Sans SC',sans-serif;
}
.lang-btn:hover{
  background:rgba(255,255,255,0.12);
  border-color:rgba(255,255,255,0.2);
  color:#f4f4f5;
}

/* ================================================================
   HERO — Editorial, typography-forward
   No AI-purple gradient, no centered-over-dark-mesh
   ================================================================ */
.hero{
  min-height:100dvh;display:flex;flex-direction:column;
  justify-content:center;
  padding:140px 28px 100px;
  position:relative;overflow:hidden;
}
.hero::before{
  content:'';position:absolute;inset:0;
  background:
    linear-gradient(180deg,rgba(10,10,15,0) 0%,rgba(10,10,15,0.6) 100%),
    repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(255,255,255,0.008) 2px,rgba(255,255,255,0.008) 4px);
  pointer-events:none;
}
.hero-inner{max-width:800px;position:relative;z-index:1}
.hero-badge{
  display:inline-block;padding:6px 18px;
  background:rgba(168,85,247,0.1);
  border:1px solid rgba(168,85,247,0.2);
  border-radius:24px;font-size:0.8rem;
  font-weight:500;color:#c4b5fd;
  margin-bottom:40px;letter-spacing:0.01em;
}
.hero h1{
  font-size:clamp(2.8rem,7vw,5.5rem);
  font-weight:700;line-height:1.05;
  margin-bottom:28px;
  color:#f4f4f5;
  letter-spacing:-0.03em;
}
.hero h1 em{
  font-style:normal;
  background:linear-gradient(135deg,#c4b5fd 0%,#f472b6 100%);
  -webkit-background-clip:text;background-clip:text;
  -webkit-text-fill-color:transparent;
}
.hero-dek{
  font-size:clamp(1.05rem,2vw,1.25rem);
  color:#71717a;max-width:600px;
  margin-bottom:52px;line-height:1.75;
}
.hero-dek strong{color:#a1a1aa;font-weight:600}
.hero-cta{
  display:flex;gap:14px;flex-wrap:wrap;
}
.btn-primary{
  background:linear-gradient(135deg,#8b5cf6,#7c3aed);
  color:#fff;padding:15px 34px;border-radius:12px;
  font-weight:600;font-size:0.95rem;
  text-decoration:none;border:none;cursor:pointer;
  transition:all 0.3s;box-shadow:0 4px 24px rgba(124,58,237,0.25);
  display:inline-flex;align-items:center;gap:8px;
}
.btn-primary:hover{
  transform:translateY(-2px);
  box-shadow:0 8px 36px rgba(124,58,237,0.4);
}
.btn-ghost{
  background:rgba(255,255,255,0.04);
  border:1px solid rgba(255,255,255,0.1);
  color:#a1a1aa;padding:15px 34px;border-radius:12px;
  font-weight:600;font-size:0.95rem;
  text-decoration:none;cursor:pointer;
  transition:all 0.3s;
}
.btn-ghost:hover{
  background:rgba(255,255,255,0.08);
  border-color:rgba(255,255,255,0.2);
  color:#f4f4f5;
}

/* ================================================================
   PAIN POINTS — Before/After mini cards
   ================================================================ */
.pain-section{
  max-width:1100px;margin:0 auto;
  padding:0 28px 100px;
}
.pain-section .section-eyebrow{
  display:block;font-size:0.72rem;font-weight:700;
  text-transform:uppercase;letter-spacing:0.1em;
  color:#8b5cf6;margin-bottom:20px;
}
.pain-section h2{
  font-size:clamp(1.6rem,3.5vw,2.2rem);
  font-weight:700;color:#f4f4f5;
  margin-bottom:12px;
}
.pain-section .section-sub{
  font-size:1rem;color:#71717a;
  max-width:520px;margin-bottom:48px;
}
.pain-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:18px;
}
@media(max-width:900px){.pain-grid{grid-template-columns:1fr}}
.pain-card{
  background:#0e0e17;
  border:1px solid rgba(255,255,255,0.04);
  border-radius:18px;padding:28px 24px;
  transition:all 0.3s;
  position:relative;overflow:hidden;
}
.pain-card:hover{
  border-color:rgba(255,255,255,0.1);
  transform:translateY(-3px);
}
.pain-card .pain-before{
  font-size:0.8rem;color:#ef4444;font-weight:600;
  margin-bottom:8px;display:flex;align-items:center;gap:6px;
}
.pain-card .pain-arrow{
  display:block;font-size:1.4rem;color:#52525b;
  margin:12px 0;
}
.pain-card .pain-after{
  font-size:0.9rem;color:#2dd4bf;font-weight:600;
  display:flex;align-items:center;gap:6px;
}
.pain-card p{
  font-size:0.85rem;color:#a1a1aa;
  line-height:1.6;margin-top:8px;
}

/* ================================================================
   SECTION HEADERS — Clean, editorial
   ================================================================ */
.section-header{
  text-align:center;padding:0 28px 52px;
  max-width:700px;margin:0 auto;
}
.section-spacer{height:80px}
.section-header .eyebrow{
  display:inline-block;padding:4px 16px;
  background:rgba(168,85,247,0.08);
  border:1px solid rgba(168,85,247,0.15);
  border-radius:20px;font-size:0.72rem;
  font-weight:600;color:#a78bfa;
  text-transform:uppercase;letter-spacing:0.08em;
  margin-bottom:18px;
}
.section-header h2{
  font-size:clamp(1.7rem,4vw,2.6rem);
  font-weight:700;margin-bottom:12px;
  color:#f4f4f5;
  letter-spacing:-0.02em;
}
.section-header p{
  font-size:1rem;color:#71717a;
  max-width:540px;margin:0 auto;line-height:1.7;
}

/* ================================================================
   BENTO MODULE GRID — Asymmetric spans, VARIANCE 8
   ================================================================ */
.module-bento{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:20px;
  padding:0 28px 100px;
  max-width:1280px;
  margin:0 auto;
}
@media(max-width:1024px){
  .module-bento{grid-template-columns:repeat(2,1fr)}
  .module-bento .bento-feature{grid-column:span 2}
  .module-bento .bento-full{grid-column:span 2}
}
@media(max-width:640px){
  .module-bento{grid-template-columns:1fr;padding:0 18px 70px}
  .module-bento .bento-feature,
  .module-bento .bento-full,
  .module-bento .bento-tall{grid-column:span 1}
}
.bento-feature{grid-column:span 2}
.bento-tall{grid-column:span 1;grid-row:span 1}
.bento-full{grid-column:span 3}

/* --- Module Card Base --- */
.mod-card{
  background:#0e0e17;
  border:1px solid rgba(255,255,255,0.04);
  border-radius:22px;overflow:hidden;
  transition:all 0.4s cubic-bezier(0.4,0,0.2,1);
  display:flex;flex-direction:column;
  position:relative;
}
.mod-card:hover{
  border-color:rgba(255,255,255,0.1);
  transform:translateY(-4px);
  box-shadow:0 24px 64px rgba(0,0,0,0.5),
             0 0 0 1px rgba(139,92,246,0.08);
}

/* --- Photo Area --- */
.mod-card .photo-area{
  width:100%;position:relative;overflow:hidden;
  flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
}
.photo-area .photo-label{
  font-family:'Space Grotesk',sans-serif;
  font-size:0.8rem;font-weight:600;
  color:rgba(255,255,255,0.65);
  text-align:center;padding:20px;
  z-index:1;
  line-height:1.5;
}
.photo-area .photo-icon{
  font-size:2.8rem;margin-bottom:10px;display:block;
}

/* Aspect ratios vary by card for VARIANCE */
.mod-card.teacher-card .photo-area{aspect-ratio:16/8}
.mod-card.student-card .photo-area{aspect-ratio:3/4}
.mod-card.parent-card .photo-area{aspect-ratio:4/3}
.mod-card.tracker-card .photo-area{aspect-ratio:16/9}
.mod-card.engine-card .photo-area{aspect-ratio:21/9}

/* Photo gradient backgrounds */
.photo-teacher{background:linear-gradient(160deg,#1e1b4b 0%,#312e81 25%,#4338ca 55%,#6366f1 100%)}
.photo-student{background:linear-gradient(160deg,#1a1a2e 0%,#16213e 25%,#1a1a4e 55%,#533483 100%)}
.photo-parent{background:linear-gradient(160deg,#0f2027 0%,#1b3a36 25%,#2c5364 60%,#1a936f 100%)}
.photo-tracker{background:linear-gradient(160deg,#1b0a1e 0%,#371b3b 30%,#5c2d63 60%,#b83b5e 100%)}
.photo-engine{background:linear-gradient(160deg,#0d0d1a 0%,#1a1a3e 30%,#2d1b69 60%,#6d28d9 100%)}

/* --- Card Body --- */
.mod-card .card-body{padding:26px;flex:1;display:flex;flex-direction:column}
.mod-card .card-body h3{
  font-size:1.3rem;font-weight:700;
  margin-bottom:10px;color:#f4f4f5;
  letter-spacing:-0.01em;
}
.mod-card .card-body .card-desc{
  font-size:0.9rem;color:#a1a1aa;
  line-height:1.7;margin-bottom:16px;flex:1;
}
.card-tags{
  display:flex;flex-wrap:wrap;gap:7px;
  margin-bottom:16px;
}
.tag{
  display:inline-block;padding:4px 12px;
  background:rgba(139,92,246,0.08);
  border:1px solid rgba(139,92,246,0.12);
  border-radius:14px;font-size:0.7rem;
  font-weight:500;color:#a78bfa;
  white-space:nowrap;
}
.tag-teal{
  background:rgba(45,212,191,0.08);
  border-color:rgba(45,212,191,0.12);
  color:#2dd4bf;
}
.card-quote{
  font-size:0.88rem;font-style:italic;
  color:#818cf8;font-weight:500;
  padding-top:14px;
  border-top:1px solid rgba(255,255,255,0.04);
  margin-top:auto;
  line-height:1.6;
}

/* Scenario callout inside cards */
.scenario-callout{
  background:rgba(139,92,246,0.05);
  border:1px solid rgba(139,92,246,0.08);
  border-radius:12px;padding:14px 16px;
  margin-top:12px;font-size:0.82rem;
  color:#a78bfa;line-height:1.6;
}
.scenario-callout strong{color:#c4b5fd}

/* ================================================================
   STUDENT STORY — Full-width editorial pull-quote
   ================================================================ */
.story-section{
  max-width:900px;margin:0 auto;
  padding:0 28px 100px;
}
.story-card{
  background:#0e0e17;
  border:1px solid rgba(255,255,255,0.04);
  border-radius:22px;padding:40px 36px;
  display:grid;grid-template-columns:1fr 1fr;
  gap:32px;align-items:center;
  position:relative;overflow:hidden;
}
@media(max-width:700px){
  .story-card{grid-template-columns:1fr;padding:28px 22px}
}
.story-card::before{
  content:'"';position:absolute;
  top:-30px;left:20px;
  font-size:12rem;font-family:'Space Grotesk',serif;
  color:rgba(139,92,246,0.06);line-height:1;
  pointer-events:none;
}
.story-photo{
  width:100%;aspect-ratio:1/1;
  border-radius:16px;
  background:linear-gradient(160deg,#1a1a2e 0%,#16213e 30%,#2d1b69 60%,#6366f1 100%);
  display:flex;align-items:center;justify-content:center;
  position:relative;z-index:1;
  overflow:hidden;
}
.story-photo .photo-label{
  font-size:0.75rem;color:rgba(255,255,255,0.55);
  text-align:center;padding:16px;
  font-family:'Space Grotesk',sans-serif;
}
.story-text{position:relative;z-index:1}
.story-text .story-name{
  font-size:1.3rem;font-weight:700;color:#f4f4f5;
  margin-bottom:8px;
}
.story-text .story-meta{
  font-size:0.8rem;color:#8b5cf6;font-weight:600;
  margin-bottom:18px;
}
.story-text .story-quote{
  font-size:1.05rem;color:#a1a1aa;
  line-height:1.75;margin-bottom:20px;
  font-style:italic;
}
.story-text .story-result{
  display:flex;gap:24px;flex-wrap:wrap;
}
.story-stat{
  text-align:center;
}
.story-stat .stat-num{
  font-family:'Space Grotesk',sans-serif;
  font-size:2rem;font-weight:700;
  background:linear-gradient(135deg,#c4b5fd,#f472b6);
  -webkit-background-clip:text;background-clip:text;
  -webkit-text-fill-color:transparent;
}
.story-stat .stat-label{
  font-size:0.72rem;color:#71717a;margin-top:2px;
}

/* ================================================================
   PEDAGOGY DEEP DIVE — Redesigned cards
   ================================================================ */
.pedagogy-section{
  max-width:1100px;margin:0 auto;
  padding:0 28px 100px;
}
.ped-card{
  background:#0e0e17;
  border:1px solid rgba(255,255,255,0.04);
  border-radius:22px;padding:34px 30px;
  margin-bottom:20px;
  transition:all 0.35s;
  position:relative;overflow:hidden;
}
.ped-card:hover{
  border-color:rgba(255,255,255,0.1);
  box-shadow:0 16px 48px rgba(0,0,0,0.4);
}
.ped-card::after{
  content:'';position:absolute;top:0;right:0;
  width:200px;height:200px;
  background:radial-gradient(circle,rgba(139,92,246,0.04),transparent 70%);
  pointer-events:none;
}
.ped-card h4{
  font-family:'Space Grotesk',sans-serif;
  font-size:1.1rem;font-weight:700;
  color:#c4b5fd;margin-bottom:20px;
  display:flex;align-items:center;gap:8px;
}
.ped-card h4 .ped-emoji{font-size:1.3rem}
.ped-row{
  display:grid;grid-template-columns:1fr 1fr 1fr;
  gap:18px;
}
@media(max-width:768px){
  .ped-row{grid-template-columns:1fr}
}
.ped-col{
  background:rgba(255,255,255,0.015);
  border-radius:14px;padding:20px;
  border:1px solid rgba(255,255,255,0.03);
  transition:all 0.25s;
}
.ped-col:hover{
  background:rgba(255,255,255,0.025);
  border-color:rgba(255,255,255,0.06);
}
.ped-col .ped-label{
  font-size:0.7rem;font-weight:700;
  text-transform:uppercase;letter-spacing:0.1em;
  margin-bottom:10px;color:#a78bfa;
}
.ped-col p{
  font-size:0.83rem;color:#a1a1aa;
  line-height:1.7;
}

/* ================================================================
   NUMBERS DASHBOARD — Clean stat cards
   ================================================================ */
.stats-row{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:16px;
  max-width:1100px;margin:0 auto;
  padding:0 28px 100px;
}
@media(max-width:900px){.stats-row{grid-template-columns:repeat(2,1fr)}}
@media(max-width:500px){.stats-row{grid-template-columns:1fr}}
.stat-card{
  background:#0e0e17;
  border:1px solid rgba(255,255,255,0.04);
  border-radius:18px;padding:28px 22px;
  text-align:center;
  transition:all 0.3s;
}
.stat-card:hover{
  border-color:rgba(255,255,255,0.1);
  transform:translateY(-2px);
}
.stat-card .big-num{
  font-family:'Space Grotesk',sans-serif;
  font-size:2.8rem;font-weight:700;
  background:linear-gradient(135deg,#c4b5fd,#a78bfa);
  -webkit-background-clip:text;background-clip:text;
  -webkit-text-fill-color:transparent;
  line-height:1.1;margin-bottom:6px;
}
.stat-card .big-num.pink{
  background:linear-gradient(135deg,#f472b6,#fb7185);
  -webkit-background-clip:text;background-clip:text;
  -webkit-text-fill-color:transparent;
}
.stat-card .big-num.teal{
  background:linear-gradient(135deg,#2dd4bf,#14b8a6);
  -webkit-background-clip:text;background-clip:text;
  -webkit-text-fill-color:transparent;
}
.stat-card .stat-desc{
  font-size:0.83rem;color:#71717a;
  line-height:1.5;
}

/* ================================================================
   ARCHITECTURE — Clean 4-layer grid
   ================================================================ */
.arch-section{
  max-width:1100px;margin:0 auto;
  padding:0 28px 100px;
}
.arch-diagram{
  background:#0e0e17;
  border:1px solid rgba(255,255,255,0.04);
  border-radius:22px;padding:36px;
  display:grid;grid-template-columns:1fr 1fr;
  gap:20px;
}
@media(max-width:768px){
  .arch-diagram{grid-template-columns:1fr;padding:24px}
}
.arch-layer{
  background:rgba(255,255,255,0.015);
  border-radius:16px;padding:26px;
  border:1px solid rgba(255,255,255,0.03);
  transition:all 0.3s;
}
.arch-layer:hover{
  background:rgba(255,255,255,0.025);
  border-color:rgba(255,255,255,0.08);
}
.arch-layer h4{
  font-family:'Space Grotesk',sans-serif;
  font-size:0.95rem;font-weight:700;
  color:#a78bfa;margin-bottom:14px;
  display:flex;align-items:center;gap:8px;
}
.arch-layer ul{
  list-style:none;padding:0;
}
.arch-layer li{
  font-size:0.83rem;color:#a1a1aa;
  padding:6px 0;line-height:1.6;
  display:flex;align-items:flex-start;gap:8px;
}
.arch-layer li::before{
  content:'▸';color:#8b5cf6;font-size:0.6rem;
  flex-shrink:0;margin-top:4px;
}

/* ================================================================
   MOAT — Bento grid, varied shapes
   ================================================================ */
.moat-bento{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:18px;max-width:1100px;margin:0 auto;
  padding:0 28px 100px;
}
@media(max-width:900px){
  .moat-bento{grid-template-columns:repeat(2,1fr)}
  .moat-bento .moat-wide{grid-column:span 2}
}
@media(max-width:560px){
  .moat-bento{grid-template-columns:1fr;padding:0 18px 70px}
  .moat-bento .moat-wide{grid-column:span 1}
}
.moat-wide{grid-column:span 2}
.moat-tall{grid-column:span 1;grid-row:span 1}

.moat-card{
  background:#0e0e17;
  border:1px solid rgba(255,255,255,0.04);
  border-radius:20px;padding:30px 26px;
  transition:all 0.35s;
  position:relative;
}
.moat-card:hover{
  border-color:rgba(255,255,255,0.1);
  transform:translateY(-3px);
  box-shadow:0 16px 48px rgba(0,0,0,0.4);
}
.moat-icon{font-size:2.4rem;margin-bottom:18px;display:block}
.moat-card h4{
  font-family:'Space Grotesk',sans-serif;
  font-size:1.05rem;font-weight:700;
  color:#f4f4f5;margin-bottom:10px;
}
.moat-card p{
  font-size:0.85rem;color:#a1a1aa;
  line-height:1.7;
}

/* ================================================================
   PHASED ROLLOUT — Timeline
   ================================================================ */
.phases{
  max-width:950px;margin:0 auto;
  padding:0 28px 100px;
}
.phase-timeline{
  display:flex;gap:18px;
  position:relative;
}
@media(max-width:768px){
  .phase-timeline{flex-direction:column}
}
.phase-timeline::before{
  content:'';position:absolute;top:36px;left:0;right:0;
  height:2px;
  background:linear-gradient(90deg,rgba(139,92,246,0.3),rgba(244,114,182,0.3));
  z-index:0;
}
@media(max-width:768px){
  .phase-timeline::before{display:none}
}
.phase{
  flex:1;background:#0e0e17;
  border:1px solid rgba(255,255,255,0.04);
  border-radius:20px;padding:30px 24px;
  text-align:center;position:relative;z-index:1;
  transition:all 0.35s;
}
.phase:hover{
  border-color:rgba(255,255,255,0.1);
  transform:translateY(-4px);
  box-shadow:0 16px 48px rgba(0,0,0,0.4);
}
.phase-num{
  width:52px;height:52px;border-radius:50%;
  background:linear-gradient(135deg,#8b5cf6,#7c3aed);
  color:#fff;font-weight:700;font-size:1.15rem;
  display:flex;align-items:center;justify-content:center;
  margin:0 auto 18px;
  font-family:'Space Grotesk',sans-serif;
}
.phase .phase-sub{
  font-size:0.7rem;color:#8b5cf6;
  font-weight:600;margin-bottom:10px;
  text-transform:uppercase;letter-spacing:0.06em;
}
.phase h4{
  font-family:'Space Grotesk',sans-serif;
  font-size:1rem;font-weight:700;
  color:#f4f4f5;margin-bottom:10px;
}
.phase p{
  font-size:0.83rem;color:#a1a1aa;
  line-height:1.7;
}

/* ================================================================
   TESTIMONIALS — Editorial pull quotes
   ================================================================ */
.testimonial-section{
  max-width:900px;margin:0 auto;
  padding:0 28px 100px;
}
.testimonial-card{
  background:#0e0e17;
  border:1px solid rgba(255,255,255,0.04);
  border-radius:22px;padding:36px 32px;
  margin-bottom:18px;
  position:relative;
  transition:all 0.3s;
}
.testimonial-card:hover{
  border-color:rgba(255,255,255,0.1);
}
.testimonial-card .t-quote{
  font-size:1.05rem;color:#d4d4d8;
  line-height:1.8;margin-bottom:16px;
  font-style:italic;
}
.testimonial-card .t-author{
  font-size:0.88rem;color:#a78bfa;font-weight:600;
}
.testimonial-card .t-role{
  font-size:0.78rem;color:#71717a;
}

/* ================================================================
   CTA — Clean close
   ================================================================ */
.cta-section{
  text-align:center;padding:0 28px 140px;
  position:relative;overflow:hidden;
}
.cta-section h2{
  font-size:clamp(1.8rem,4vw,2.6rem);
  font-weight:700;color:#f4f4f5;
  margin-bottom:18px;
  letter-spacing:-0.02em;
}
.cta-section p{
  font-size:1.05rem;color:#71717a;
  max-width:560px;margin:0 auto 36px;
  line-height:1.75;
}
.cta-buttons{
  display:flex;gap:14px;justify-content:center;flex-wrap:wrap;
}

/* ================================================================
   FOOTER
   ================================================================ */
.footer{
  text-align:center;padding:44px 28px;
  border-top:1px solid rgba(255,255,255,0.03);
  font-size:0.78rem;color:#52525b;
  line-height:1.7;
}

/* ================================================================
   ANIMATIONS — Subtle entrance, MOTION 5
   ================================================================ */
.fade-up{
  opacity:0;transform:translateY(24px);
  transition:opacity 0.7s ease,transform 0.7s ease;
}
.fade-up.visible{opacity:1;transform:translateY(0)}

/* ================================================================
   PRINT
   ================================================================ */
@media print{
  body{background:#fff;color:#111;font-size:11px}
  .mod-card,.ped-card,.moat-card,.phase,.arch-layer,.testimonial-card,
  .stat-card,.story-card,.pain-card{background:#f8f8f8;border:1px solid #ddd;break-inside:avoid}
  .toggle-bar{display:none}
  .hero{min-height:auto;padding:40px 28px}
  .hero h1{-webkit-text-fill-color:#111;background:none;color:#111}
  .logo{-webkit-text-fill-color:#111;background:none;color:#111}
  .btn-primary,.btn-ghost{border:1px solid #333;color:#111;background:#eee}
  .module-bento,.moat-bento{grid-template-columns:1fr 1fr}
}
</style>
</head>
