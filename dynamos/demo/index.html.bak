<!-- ===== HERO ===== -->
<section class="hero">
  <div class="hero-inner">
    <div class="hero-badge fade-up"><span data-lang-zh>🎓 面向教育机构的 AI 操作系统</span><span data-lang-en>🎓 AI Operating System for Schools</span></div>
    <h1 class="fade-up">Dynam<em>OS</em></h1>
    <p class="hero-dek fade-up">
      <span data-lang-zh class="block">
